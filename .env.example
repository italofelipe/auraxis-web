# API
NUXT_PUBLIC_API_BASE=http://localhost:5000

# Sentry — error tracking (opt-in: deixe em branco para desabilitar)
NUXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
NUXT_PUBLIC_APP_ENV=development

# Site
NUXT_PUBLIC_SITE_URL=https://app.auraxis.com.br

# BRAPI — market data API for ticker autocomplete and historical prices
# Register at https://brapi.dev to obtain a free API key.
NUXT_PUBLIC_BRAPI_API_KEY=

# Sonar
SONAR_AURAXIS_WEB_TOKEN=
