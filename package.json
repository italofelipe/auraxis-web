{
  "name": "auraxis-web",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "nuxt typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "quality-check": "pnpm lint && pnpm typecheck && pnpm test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "prepare": "husky"
  },
  "dependencies": {
    "@bubblesortt/nuxt-es-toolkit": "1.0.10",
    "@nuxt/a11y": "1.0.0-alpha.1",
    "@nuxt/content": "3.11.2",
    "@nuxt/hints": "1.0.0-alpha.7",
    "@nuxt/image": "2.0.0",
    "@nuxt/scripts": "0.13.2",
    "@nuxt/ui": "4.4.0",
    "@nuxtjs/device": "4.0.0",
    "@nuxtjs/google-fonts": "3.2.0",
    "@nuxtjs/i18n": "10.2.3",
    "@nuxtjs/seo": "3.4.0",
    "@pinia/colada-nuxt": "0.3.1",
    "@pinia/nuxt": "0.11.3",
    "better-sqlite3": "^12.6.2",
    "dayjs-nuxt": "2.1.11",
    "nuxt": "^4.3.1",
    "vue": "^3.5.28",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@nuxt/eslint": "1.15.1",
    "@nuxt/test-utils": "4.0.0",
    "@nuxtjs/storybook": "9.0.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/vue": "^8.1.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.39.3",
    "happy-dom": "^20.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "storybook": "9.1.17",
    "typescript": "^5.8.3",
    "vitest": "^4.0.18",
    "vue-tsc": "^2.2.12"
  },
  "packageManager": "pnpm@10.30.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "better-sqlite3",
      "esbuild",
      "sharp",
      "unrs-resolver",
      "vue-demi"
    ]
  },
  "lint-staged": {
    "**/*.{ts,tsx,vue}": [
      "eslint --fix"
    ],
    "**/*.{json,jsonc,md}": [
      "prettier --write"
    ]
  }
}
