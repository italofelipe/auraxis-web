{
  "name": "auraxis-web",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "typecheck": "nuxt typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --coverage.reporter=text --coverage.reporter=json --coverage.reporter=json-summary --coverage.reporter=html --coverage.reporter=lcovonly",
    "flags:check": "node scripts/check-feature-flags.cjs",
    "contracts:sync": "node scripts/contracts-sync.cjs",
    "contracts:check": "node scripts/contracts-check.cjs",
    "policy:check": "node scripts/check-frontend-governance.cjs",
    "quality-check": "pnpm lint && pnpm typecheck && pnpm test:coverage && pnpm policy:check && pnpm contracts:check",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "prepare": "husky",
    "ci:local": "bash scripts/run_ci_like_actions_local.sh",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build"
  },
  "dependencies": {
    "@bubblesortt/nuxt-es-toolkit": "1.0.10",
    "@css-render/vue3-ssr": "^0.15.14",
    "@nuxt/a11y": "1.0.0-alpha.1",
    "@nuxt/content": "3.11.2",
    "@nuxt/hints": "1.0.2",
    "@nuxt/image": "2.0.0",
    "@nuxt/scripts": "0.13.2",
    "@nuxtjs/device": "4.0.0",
    "@nuxtjs/google-fonts": "3.2.0",
    "@nuxtjs/i18n": "10.2.3",
    "@nuxtjs/seo": "3.4.0",
    "@pinia/nuxt": "0.11.3",
    "@sentry/nuxt": "^10.45.0",
    "@sentry/vue": "^10.45.0",
    "@tanstack/vue-query": "^5.95.0",
    "@vee-validate/zod": "^4.15.1",
    "axios": "^1.13.6",
    "better-sqlite3": "^12.8.0",
    "css-render": "^0.15.14",
    "dayjs-nuxt": "2.1.11",
    "echarts": "^6.0.0",
    "lucide-vue-next": "^0.577.0",
    "naive-ui": "^2.44.1",
    "nuxt": "^4.4.2",
    "pinia": "^3.0.4",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.30",
    "vue-echarts": "^8.0.1",
    "vue-router": "^5.0.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@nuxt/eslint": "1.15.2",
    "@nuxt/test-utils": "4.0.0",
    "@nuxtjs/storybook": "9.0.1",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-a11y": "9.1.20",
    "@storybook/vue3": "9.1.20",
    "@testing-library/vue": "^8.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.39.4",
    "eslint-plugin-jsdoc": "^54.5.0",
    "happy-dom": "^20.8.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "openapi-typescript": "^7.10.1",
    "prettier": "^3.8.1",
    "storybook": "9.1.20",
    "typescript": "^5.8.3",
    "vitest": "^4.1.0",
    "vue-tsc": "^2.2.12"
  },
  "engines": {
    "node": "25.x"
  },
  "packageManager": "pnpm@10.30.1",
  "pnpm": {
    "overrides": {
      "@rollup/plugin-terser@0.4.4>serialize-javascript": "7.0.3",
      "svgo": "4.0.1",
      "tar": "7.5.11",
      "simple-git": ">=3.32.3",
      "fast-xml-parser": ">=5.5.6",
      "socket.io-parser": ">=4.2.6",
      "flatted": ">=3.4.2",
      "picomatch": ">=4.0.4",
      "node-forge": ">=1.4.0"
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "better-sqlite3",
      "esbuild",
      "sharp",
      "unrs-resolver",
      "vue-demi"
    ]
  },
  "lint-staged": {
    "**/*.{ts,tsx,vue}": [
      "eslint --fix --max-warnings 0 --no-warn-ignored",
      "node scripts/check-frontend-governance.cjs"
    ],
    "**/*.{json,jsonc,md}": [
      "prettier --write"
    ]
  },
  "version": "1.0.0"
}
