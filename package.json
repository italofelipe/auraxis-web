{
  "name": "auraxis-web",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "typecheck": "nuxt typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "flags:check": "node scripts/check-feature-flags.cjs",
    "i18n:check": "node scripts/check-i18n-parity.cjs",
    "contracts:sync": "node scripts/contracts-sync.cjs",
    "contracts:check": "node scripts/contracts-check.cjs",
    "analyze": "ANALYZE=true pnpm build && node scripts/analyze-bundle.cjs",
    "analyze:report": "node scripts/analyze-bundle.cjs",
    "policy:check": "node scripts/check-frontend-governance.cjs",
    "audit:critical": "pnpm audit --audit-level=critical",
    "audit:high": "pnpm audit --audit-level=high",
    "bundle:budget": "ANALYZE=true pnpm build && node scripts/analyze-bundle.cjs",
    "lighthouse:budget": "pnpm dlx @lhci/cli@0.15.x autorun --config=.lighthouserc.yml",
    "codegen": "graphql-codegen --config codegen.ts",
    "codegen:check": "graphql-codegen --config codegen.ts && git diff --exit-code app/shared/types/generated/graphql.ts",
    "quality-check": "pnpm flags:check && pnpm i18n:check && pnpm lint && pnpm typecheck && pnpm test:coverage && pnpm policy:check && pnpm contracts:check && pnpm codegen:check && pnpm build",
    "mutation": "stryker run",
    "mutation:quick": "stryker run --mutate 'app/schemas/validators.ts'",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "prepare": "husky",
    "ci:local": "bash scripts/run_ci_like_actions_local.sh",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "build-storybook": "storybook build",
    "test-storybook": "test-storybook --url http://localhost:6006 --testTimeout 15000"
  },
  "dependencies": {
    "@bubblesortt/nuxt-es-toolkit": "1.0.10",
    "@css-render/vue3-ssr": "^0.15.14",
    "@nuxt/a11y": "1.0.0-alpha.1",
    "@nuxt/content": "3.14.0",
    "@nuxt/hints": "1.1.2",
    "@nuxt/scripts": "0.13.4",
    "@nuxtjs/device": "4.0.0",
    "@nuxtjs/google-fonts": "3.2.0",
    "@nuxtjs/i18n": "10.4.0",
    "@nuxtjs/seo": "3.4.0",
    "@pinia/nuxt": "0.11.3",
    "@sentry/nuxt": "^10.55.0",
    "@sentry/vue": "^10.55.0",
    "@tanstack/vue-query": "^5.100.14",
    "@vee-validate/zod": "^4.15.1",
    "axios": "^1.16.1",
    "axios-retry": "^4.5.0",
    "better-sqlite3": "^12.10.0",
    "css-render": "^0.15.14",
    "dayjs": "1.11.21",
    "dayjs-nuxt": "2.1.11",
    "echarts": "^6.1.0",
    "lucide-vue-next": "^0.577.0",
    "naive-ui": "^2.44.1",
    "nuxt": "^4.4.6",
    "pinia": "^3.0.4",
    "vee-validate": "^4.15.1",
    "vue": "^3.5.35",
    "vue-echarts": "^8.0.1",
    "vue-router": "^5.1.0",
    "web-vitals": "^5.3.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@graphql-codegen/cli": "^7.0.0",
    "@graphql-codegen/typed-document-node": "^7.0.3",
    "@graphql-codegen/typescript": "^6.0.2",
    "@graphql-codegen/typescript-operations": "^6.0.3",
    "@nuxt/eslint": "1.15.2",
    "@nuxt/test-utils": "4.0.3",
    "@nuxtjs/storybook": "9.0.1",
    "@playwright/test": "^1.60.0",
    "@storybook/addon-a11y": "9.1.20",
    "@storybook/test-runner": "^0.24.4",
    "@storybook/vue3": "9.1.20",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@testing-library/vue": "^8.1.0",
    "@vite-pwa/nuxt": "^1.1.1",
    "@vitest/coverage-v8": "^4.1.8",
    "@vue/test-utils": "^2.4.10",
    "eslint": "^9.39.4",
    "eslint-plugin-jsdoc": "^54.5.0",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "graphql": "^16.14.1",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "msw": "^2.14.6",
    "openapi-typescript": "^7.10.1",
    "posthog-js": "^1.376.0",
    "prettier": "^3.8.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "storybook": "9.1.20",
    "typescript": "^5.8.3",
    "vite": "7.3.5",
    "vitest": "^4.1.8",
    "vue-tsc": "^2.2.12"
  },
  "engines": {
    "node": "25.x"
  },
  "packageManager": "pnpm@10.30.1",
  "pnpm": {
    "overrides": {
      "svgo": "4.0.1",
      "tar": "7.5.11",
      "simple-git": ">=3.36.0",
      "fast-xml-parser": ">=5.7.0",
      "fast-xml-builder": ">=1.1.7",
      "fast-uri": ">=3.1.2",
      "@babel/plugin-transform-modules-systemjs": ">=7.29.4",
      "socket.io-parser": ">=4.2.6",
      "flatted": ">=3.4.2",
      "picomatch": ">=4.0.4",
      "node-forge": ">=1.4.0",
      "defu": ">=6.1.5",
      "devalue": "5.8.1",
      "vite": "7.3.5",
      "serialize-javascript": ">=7.0.5",
      "protobufjs": ">=7.5.5",
      "follow-redirects": ">=1.16.0",
      "unhead": ">=2.1.13",
      "nuxt-og-image": ">=6.2.5",
      "js-yaml": ">=4.1.1",
      "dompurify": ">=3.4.0",
      "lodash-es": "4.17.23",
      "js-cookie": ">=3.0.7"
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "better-sqlite3",
      "esbuild",
      "sharp",
      "unrs-resolver",
      "vue-demi"
    ]
  },
  "lint-staged": {
    "**/*.{ts,tsx,vue}": [
      "eslint --fix --max-warnings 0 --no-warn-ignored",
      "node scripts/check-frontend-governance.cjs"
    ],
    "**/*.{json,jsonc,md}": [
      "prettier --write"
    ]
  },
  "version": "1.0.0"
}
