#!/usr/bin/env sh
# Pre-push hook — mirrors GitHub Actions CI pipeline locally.
# Catches failures before they reach remote.
#
# E2E is opt-in because local preview server + mock routing can diverge
# from CI. Run manually with: pnpm test:e2e --project=chromium --project=mobile-chrome
# Or enable in hook with: RUN_E2E=1 git push
#
# Skip the entire hook with: git push --no-verify (use sparingly)

set -e

echo "══════════════════════════════════════════════════════"
echo "  Pre-push CI parity gate"
echo "══════════════════════════════════════════════════════"

echo ""
echo "▸ [1/8] Feature flags hygiene..."
pnpm flags:check

echo ""
echo "▸ [2/8] Lint (ESLint)..."
pnpm lint

echo ""
echo "▸ [3/8] TypeScript (strict)..."
npx nuxi typecheck

echo ""
echo "▸ [4/8] Unit tests + coverage..."
npx vitest run --coverage

echo ""
echo "▸ [5/8] Frontend governance + contracts..."
pnpm policy:check
pnpm contracts:check

echo ""
echo "▸ [6/8] Dependency audit (ci-audit-gate: high+critical, allowlist-aware)..."
# Uses the same script CI runs (scripts/ci-audit-gate.cjs). It blocks on
# high+critical vulnerabilities EXCEPT those in the allowlist (transitives
# without upstream patches, e.g., lodash-es _.template / minimatch ReDoS in
# js-cookie chain — see ADR/issue refs inside the script). Tighter than the
# previous `pnpm audit:critical` baseline.
node scripts/ci-audit-gate.cjs

echo ""
echo "▸ [7/8] Build..."
pnpm build

echo ""
if [ "${RUN_E2E:-0}" = "1" ]; then
  echo "▸ [8/8] E2E (Playwright — chromium + mobile-chrome)..."
  pnpm test:e2e --project=chromium --project=mobile-chrome
else
  echo "▸ [8/8] E2E (skipped — opt-in with RUN_E2E=1 git push)"
fi

echo ""
echo "══════════════════════════════════════════════════════"
echo "  All pre-push checks passed."
echo "══════════════════════════════════════════════════════"
